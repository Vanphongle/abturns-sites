# Copy to .env.local. PUBLIC values only — this app deliberately carries no
# secrets (reads go through the publishable key + published-only RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Base domain for {slug}.<base> preview subdomains (must be on Vercel nameservers).
NEXT_PUBLIC_PREVIEW_BASE_DOMAIN=
# Public booking flow base URL, e.g. https://abturns.com/book
NEXT_PUBLIC_BOOKING_BASE=https://abturns.com/book
